@startuml

skinparam componentStyle uml2
skinparam shadowing false
skinparam monochrome true
skinparam linetype polyline

node "Orchestrator Process" {
    artifact "DAGOrchestrator" as ORCH
    artifact "Dragon Batch DAG" as BATCH
    artifact "HitlTcpBridge" as HITL_BRIDGE
    artifact "TraceTcpBridge" as TRACE_BRIDGE
}

database "Scoreboard DDict" as SB

node "Agent Process (Planner)" {
    artifact "SubAgent" as A1
    artifact "ToolDispatcher" as TD1
    artifact "ToolRegistry" as TR1
    artifact "ContextManager" as CM1
}

node "Agent Process (Runner)" {
    artifact "SubAgent" as A2
    artifact "ToolDispatcher" as TD2
    artifact "ToolRegistry" as TR2
    artifact "ContextManager" as CM2
}

cloud "LLM Service\n(vLLM)" as LLM
cloud "MCP Servers" as MCP
actor "Human Operator" as HUMAN
actor "Trace Viewer" as VIEWER

ORCH -- BATCH : builds DAG
BATCH --> A1 : DispatchHeader\nvia Dragon Queue
BATCH --> A2 : DispatchHeader\nvia Dragon Queue

A1 -- TD1
TD1 -- TR1 : local tools
TD1 -- CM1 : conversation memory

A2 -- TD2
TD2 -- TR2 : local tools
TD2 -- CM2 : conversation memory

A1 <--> SB : read upstream /\nwrite result + status
A2 <--> SB : read upstream /\nwrite result + status

TD1 <--> LLM : Dragon Queue\n(req/resp)
TD2 <--> LLM : Dragon Queue\n(req/resp)

TD1 <..> MCP : SSE / HTTP
TD2 <..> MCP : SSE / HTTP

HITL_BRIDGE <--> SB : hitl_queue
HITL_BRIDGE <--> HUMAN : TCP / JSON

TRACE_BRIDGE <--> SB : trace spans + events
TRACE_BRIDGE <--> VIEWER : TCP / JSONL

@enduml
