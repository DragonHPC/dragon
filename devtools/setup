#!/bin/bash

# Check whether 'uv' is available and set a flag for later use
if [[ "${1}" == "base" ]]; then
    UV_AVAILABLE=0
    echo "Using base Python (skipping uv due to 'base' argument)" >&2
elif command -v uv >/dev/null 2>&1; then
    UV_AVAILABLE=1
else
    UV_AVAILABLE=0
    echo "'uv' command not found. Install 'uv' (the venv tool) if you'd like to use it to install Python virtual environments. Falling back on base python in path." >&2
fi
export UV_AVAILABLE

DEVTOOLS_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )";
source ${DEVTOOLS_DIR}/VARIABLES

# Accept version as first arg or VENV_PY env var, default to 3.12
if [[ "${UV_AVAILABLE}" == "1" ]]; then
    default_py="3.12"
    req="${1:-${VENV_PY:-}}"
    if [[ -z "$req" ]]; then
        py_ver="$default_py"
    elif [[ "$req" =~ ^3\.[0-9]+$ ]]; then
        py_ver="$req"
    else
        echo "Warning: invalid Python version '$req', falling back to $default_py" >&2
        py_ver="$default_py"
    fi

    # Update the venv name
    env_str=_env${py_ver}
else
    env_str="_env"
fi

# if we were called from devtools/clean_build, a 2nd arg tells us
# we should clean up the old venv before creating a new one
if [[ "$@" == *"clean"* ]]; then
    # Try deactivating any active environment. Move on if unable
    deactivate || true

    # Remove existing environment
    rm -rf ${DEVTOOLS_DIR}/../${env_str}
fi

if [ ! -d "${DEVTOOLS_DIR}/../${env_str}" ]; then
    if [[ "${UV_AVAILABLE}" == "1" ]]; then
        # uv cache clean
        # create venv in the current working directory
        uv venv --python "$py_ver" --python-preference only-managed ${env_str}
    else
        echo "'uv' not available; falling back to python3 -m venv" >&2
        if command -v python3 >/dev/null 2>&1; then
             python3 -m venv ${env_str}
        else
            echo "No suitable python found to create venv. Aborting." >&2
            exit 1
        fi
    fi
fi

ppath=`which python3`

if [[ "$ppath" != *"$env_str"* ]]; then

    echo "Activating environment."
    . ${env_str}/bin/activate
fi
