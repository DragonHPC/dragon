#!/bin/bash

# Set basic environment variables
HACK_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )";
source ${HACK_DIR}/VARIABLES

# Set up python environment using setup script
source ${HACK_DIR}/setup "$@" "clean"

# Install packages based on whether uv is available
if [[ "${UV_AVAILABLE}" == "1" ]]; then
    uv pip install -U pip
    uv pip install --index-strategy unsafe-best-match -r src/requirements.txt
else
    python3 -m pip install -U pip
    python3 -m pip install -r src/requirements.txt
fi

# Make a clean src directory
make -C src distclean

echo "Building source code."
make -C src build
